{
  "name": "app-tracking-paquetes-backend",
  "version": "1.0.0",
  "private": true,
  "description": "API backend para appTrackingPaquetesAPA usando Node.js, Express, TypeScript, MongoDB y Redis.",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/servidor.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/servidor.js",
    "seed": "npm run build && node dist/semillas/usuarioDefault.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.4.0",
    "morgan": "^1.10.0",
    "redis": "^4.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.19",
    "@types/jsonwebtoken": "^9.0.3",
    "@types/morgan": "^1.9.4",
    "@types/node": "^20.14.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  }
}
